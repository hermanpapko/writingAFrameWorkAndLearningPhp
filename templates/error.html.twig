{# templates/error.html.twig #}
{% extends "base.html.twig" %}

{% block title %}{{ __('error_occurred') }}{% endblock %}

{% block body %}
    <h1>{{ __('error_occurred') }}</h1>
    <div style="color: red; border: 1px solid red; padding: 10px;">
        {{ error }}
    </div>
    <p><a href="/">{{ __('back_to_home') }}</a></p>
{% endblock %}