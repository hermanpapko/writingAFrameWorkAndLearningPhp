{% extends "base.html.twig" %}

{% block body %}
    <h1>{{ organization ? __('edit_org') : __('create_org_title') }}</h1>

    <div class="card">
        <form action="{{ organization ? '/organizations/update/' ~ organization.id : '/organizations/store' }}" method="POST">
            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px;">{{ __('org_name') }}</label>
                {# Pre-fills data if an organization object is passed #}
                <input type="text" name="name" value="{{ organization.name ?? '' }}" required style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;">
            </div>

            <button type="submit" style="padding: 10px 15px; background: #3b82f6; color: white; border: none; border-radius: 4px; cursor: pointer;">
                {{ organization ? __('update') : __('save') }}
            </button>
            <a href="/organizations" style="margin-left: 10px; color: #666; text-decoration: none;">{{ __('cancel') }}</a>
        </form>
    </div>
{% endblock %}