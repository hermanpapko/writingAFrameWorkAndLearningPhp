{% extends "base.html.twig" %}

{% block body %}
    <h1>Organizations</h1>
    <div class="card full-width">
        <a href="/organizations/create" style="padding: 10px; background: #3b82f6; color: white; text-decoration: none; border-radius: 4px; display: inline-block; margin-bottom: 20px;">Create New Organization</a>

        <table style="width: 100%; border-collapse: collapse;">
            <thead>
            <tr style="background: #f9fafb; text-align: left;">
                <th style="padding: 12px; border-bottom: 1px solid #e5e7eb;">ID</th>
                <th style="padding: 12px; border-bottom: 1px solid #e5e7eb;">Name</th>
                <th style="padding: 12px; border-bottom: 1px solid #e5e7eb;">Created At</th>
                <th style="padding: 12px; border-bottom: 1px solid #e5e7eb;">Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for org in organizations %}
                <tr>
                    <td style="padding: 12px; border-bottom: 1px solid #e5e7eb;">{{ org.id }}</td>
                    <td style="padding: 12px; border-bottom: 1px solid #e5e7eb;">{{ org.name }}</td>
                    <td style="padding: 12px; border-bottom: 1px solid #e5e7eb;">{{ org.createdAt }}</td>
                    <td style="padding: 12px; border-bottom: 1px solid #e5e7eb;">
                        <a href="/organizations/edit/{{ org.id }}" style="color: blue; text-decoration: none; margin-right: 10px;">Edit</a>
                        <form action="/organizations/delete/{{ org.id }}" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this organization? All associated users will also be deleted due to CASCADE.');">
                            <button type="submit" style="background: none; border: none; color: red; cursor: pointer; text-decoration: underline;">Delete</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="4" style="text-align: center; padding: 20px;">No organizations found.</td></tr>
            {% endfor %}
            </tbody>
        </table>

        {# Pagination #}
        {% if total_pages > 1 %}
            <div style="margin-top: 20px; display: flex; justify-content: center; gap: 5px;">
                {% if current_page > 1 %}
                    <a href="/organizations?page={{ current_page - 1 }}" style="padding: 8px 12px; border: 1px solid #ddd; text-decoration: none;">&laquo; Prev</a>
                {% endif %}
                <span style="padding: 8px 12px; border: 1px solid #ddd; background: #f3f4f6;">Page {{ current_page }} of {{ total_pages }}</span>
                {% if current_page < total_pages %}
                    <a href="/organizations?page={{ current_page + 1 }}" style="padding: 8px 12px; border: 1px solid #ddd; text-decoration: none;">Next &raquo;</a>
                {% endif %}
            </div>
        {% endif %}
    </div>
{% endblock %}