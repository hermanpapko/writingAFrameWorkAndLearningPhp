{
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1"
    },

    "autoload": {
        "psr-4": {
           "App\\": "src/"
        }
    },
    "require": {
        "fakerphp/faker": "^1.24"
    },

    "scripts": {
        "stan": "vendor/bin/phpstan analyse -c config/phpstan.neon",
        "fix": "vendor/bin/php-cs-fixer fix --config=config/.php-cs-fixer.dist.php"
    }
}
